# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Credentials used by the postgres Docker service and the app's DSN.
# Copy this file to .env.compose and adjust as needed.
POSTGRES_DB=apiguard
POSTGRES_USER=apiguard
POSTGRES_PASSWORD=apiguard

# Full DSN for the api-guard service.
# When running via docker compose, use the service name "postgres" as host.
DATABASE_DSN=postgres://apiguard:apiguard@postgres:5432/apiguard?sslmode=disable
DATABASE_DRIVER=postgres

# ── Proxy ─────────────────────────────────────────────────────────────────────
LISTEN_ADDR=:8080
UPSTREAM_TIMEOUT=30s
ENABLE_TEST_INTERFACE=false
OPENAI_BASE_URL=https://api.openai.com
ENABLE_LEGACY_FALLBACK=true

# Master key for encrypting stored provider credentials at rest.
# Generate with: openssl rand -hex 32
SECRET_MASTER_KEY=change-me-generate-with-openssl-rand-hex-32

# ── Optional legacy bootstrap ──────────────────────────────────────────────────
# UPSTREAM_BASE_URL=https://api.openai.com
# UPSTREAM_API_KEY=sk-...
# TENANT_API_KEYS=tenant-a:key-a,tenant-b:key-b
