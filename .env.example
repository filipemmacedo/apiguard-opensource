# ── Database ──────────────────────────────────────────────────────────────────
# SQLite is used by default (no config needed).
# For Postgres, set DATABASE_DRIVER and DATABASE_DSN:
# DATABASE_DRIVER=postgres
# DATABASE_DSN=postgres://apiguard:apiguard@localhost:5432/apiguard?sslmode=disable

# ── Proxy ─────────────────────────────────────────────────────────────────────
LISTEN_ADDR=:8080
UPSTREAM_TIMEOUT=30s

# Master key for encrypting stored provider credentials at rest.
# Generate with: openssl rand -hex 32
SECRET_MASTER_KEY=change-me-generate-with-openssl-rand-hex-32

# Set to true to expose a minimal HTML test interface at /internal/test-interface
ENABLE_TEST_INTERFACE=false

# ── Optional legacy bootstrap ──────────────────────────────────────────────────
# Uncomment to seed a provider and tenant keys on first start (imported into DB).
# OPENAI_BASE_URL=https://api.openai.com
# UPSTREAM_BASE_URL=https://api.openai.com
# UPSTREAM_API_KEY=sk-...
# TENANT_API_KEYS=tenant-a:key-a,tenant-b:key-b
