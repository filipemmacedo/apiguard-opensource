{
  "name": "api-guard",
  "private": true,
  "scripts": {
    "setup": "node scripts/setup.js",
    "dev": "docker compose --env-file .env.compose up -d",
    "dev:build": "docker compose --env-file .env.compose up --build -d",
    "dev:down": "docker compose --env-file .env.compose down",
    "dev:logs": "docker compose --env-file .env.compose logs -f",
    "dev:api": "go run ./cmd/apiguard",
    "dev:dashboard": "npm --prefix dashboard run dev",
    "e2e:setup": "npx tsx e2e/setup.ts"
  },
  "version": "1.0.0",
  "description": "Minimal multi-tenant LLM proxy in Go for chat completion requests.",
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/filipemmacedo/apiguard.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/filipemmacedo/apiguard/issues"
  },
  "homepage": "https://github.com/filipemmacedo/apiguard#readme",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "tsx": "^4.21.0"
  }
}
